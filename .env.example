# Copy this file to ".env" and fill in your own value.
# The .env file is gitignored — never commit a real key.
#
# Generate a tagged, reusable auth key in the Tailscale admin console:
#   https://login.tailscale.com/admin/settings/keys
# Give it the tag you advertise in docker-compose.yaml (tag:gameclock).

TS_AUTHKEY=tskey-auth-REPLACE_ME
